{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "trailingComma": "all",
  "sortImports": {
    "partitionByNewline": true,
    "newlinesBetween": false
  },
  "sortPackageJson": true,
  "ignorePatterns": ["generated", "node_modules", ".github", "logs", ".husky", ".claude"],
  "overrides": [
    {
      "files": ["apps/web/**/*.{ts,tsx}"],
      "options": {
        "sortTailwindcss": {}
      }
    }
  ]
}
