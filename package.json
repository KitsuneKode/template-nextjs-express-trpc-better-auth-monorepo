{
  "name": "template",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "toolings/*",
    "tests/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:vercel": "turbo run build:vercel",
    "dev": "turbo run dev",
    "dev:cli": "turbo -F @arche/create dev --",
    "build:cli": "turbo -F @arche/create build",
    "repo:doctor": "bun toolings/scripts/repo-doctor.ts",
    "repo:doctor:strict": "bun toolings/scripts/repo-doctor.ts --strict",
    "template:clean:dry": "bun toolings/scripts/template-cleanup.ts --dry-run",
    "template:clean": "bun toolings/scripts/template-cleanup.ts --yes",
    "commit:check": "commitlint --last --verbose",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "clean": "find . -name node_modules -o -name .next -o -name .turbo -o -name dist -type d -prune | xargs rm -rf",
    "check-types": "turbo run check-types",
    "dev:web": "turbo -F @template/web dev",
    "dev:server": "turbo -F @template/server dev",
    "dev:worker": "turbo -F @template/worker dev",
    "db:seed": "turbo db:seed",
    "db:studio": "turbo db:studio",
    "db:generate": "turbo db:generate",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "db:migrate": "turbo db:migrate",
    "rename-scope": "bun toolings/scripts/rename-scope.ts",
    "rename-scope:dry": "bun toolings/scripts/rename-scope.ts --dry-run",
    "rename-scope:verbose": "bun toolings/scripts/rename-scope.ts --verbose",
    "preinstall": "npx only-allow bun",
    "postinstall": "bun toolings/scripts/postinstall-generate.ts",
    "docker:build": "docker build -f apps/server/Dockerfile .",
    "docker:run": "docker run --rm -p 8080:8080 -e ENABLE_REDIS=false",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "@t3-oss/env-nextjs": "^0.13.11",
    "compression": "^1.7.5",
    "express-rate-limit": "^8.5.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@template/typescript-config": "workspace:*",
    "@types/compression": "^1.7.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "turbo": "^2.9.14",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9"
}
