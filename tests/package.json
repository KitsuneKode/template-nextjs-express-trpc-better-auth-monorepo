{
  "name": "@arche-template/tests",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "test:watch": "bun test --watch",
    "test": "bun test",
    "test:deploy": "RUN_DEPLOY_SMOKE=1 bun test src/integration/deploy-smoke.test.ts",
    "test:deploy:all": "RUN_DEPLOY_SMOKE=1 RENDER_API_URL=https://arche-template-api.onrender.com VERCEL_API_URL=https://template-server-kitsunekode.vercel.app bun test src/integration/deploy-smoke.test.ts",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@arche-template/auth": "workspace:*",
    "@arche-template/server": "workspace:*",
    "@arche-template/store": "workspace:*",
    "@arche-template/trpc": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
