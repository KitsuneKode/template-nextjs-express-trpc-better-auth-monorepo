{
  "compilerOptions": {
    "lib": ["ESNext", "ES7"],
    "target": "ESNext",
    "module": "esnext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "types": ["bun"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "baseUrl": "..",
    "paths": {
      "@template/server/*": ["apps/server/src/*"],
      "@template/server": ["apps/server/src/server.ts"],
      "@template/auth/*": ["packages/auth/src/*"],
      "@template/auth": ["packages/auth/src/index.ts"],
      "@template/trpc": ["packages/trpc/src/index.ts"],
      "@template/store": ["packages/store/src/index.ts"],
      "@template/common": ["packages/common/src/index.ts"],
      "@template/backend-common": ["packages/backend-common/src/index.ts"],
      "@template/ui/*": ["packages/ui/src/*"],
      "@template/ui": ["packages/ui/src/index.ts"]
    }
  }
}
