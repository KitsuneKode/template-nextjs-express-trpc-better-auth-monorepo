{
  "name": "@arche-template/server",
  "private": true,
  "type": "module",
  "main": "src/vercel-handler.ts",
  "module": "src/vercel-handler.ts",
  "exports": {
    "./app": "./src/app.ts",
    "./trpc": "./src/modules/trpc/index.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "bun build ./src/server.ts --outdir ./dist --target bun --minify --sourcemap",
    "build:vercel": "bun build ./src/vercel-handler.ts --outdir ./dist --target bun --minify --sourcemap",
    "dev": "bun run --watch src/server.ts",
    "start": "bun run dist/server.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@arche-template/auth": "workspace:*",
    "@arche-template/backend-common": "workspace:*",
    "@arche-template/store": "workspace:*",
    "@bull-board/api": "^7.1.5",
    "@bull-board/express": "^7.1.5",
    "@trpc/server": "^11.17.0",
    "bullmq": "^5.76.10",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "superjson": "^2.2.6",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@arche-template/typescript-config": "workspace:*",
    "@types/bun": "1.3.14",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
