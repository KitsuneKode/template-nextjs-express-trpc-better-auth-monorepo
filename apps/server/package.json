{
  "name": "@template/server",
  "private": true,
  "type": "module",
  "module": "src/server.ts",
  "scripts": {
    "check-types": "tsc -noEmit",
    "build": "bun build ./src/app.ts --outdir ./dist --target bun --minify --sourcemap",
    "build:vercel": "bun build ./src/app.ts --outdir ./dist --target bun --minify --sourcemap",
    "dev": "bun run --watch src/server.ts",
    "start": "bun run dist/app.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@bull-board/api": "^6.10.0",
    "@bull-board/express": "^6.10.0",
    "@template/auth": "workspace:*",
    "@template/backend-common": "workspace:*",
    "@template/store": "workspace:*",
    "@template/trpc": "workspace:*",
    "bullmq": "^5.48.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@template/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
