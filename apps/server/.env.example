# Backend environment configuration
# This file documents all backend environment variables
# Copy to .env for local development and customize as needed

# Core Configuration
PORT=8080
NODE_ENV=development

# Database (choose based on your setup)
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/my_app

# Alternative: SQLite (good for local development)
# DATABASE_URL=file:./dev.db

# Alternative: MongoDB
# DATABASE_URL=mongodb://mongo:mongo@localhost:27017/my_app?authSource=admin

# Frontend Reference
FRONTEND_URL=http://localhost:3000

# Cache/Queue
REDIS_URL=redis://localhost:6379

# Authentication (Better Auth)
# Generate a secure random string (at least 32 characters) for production
BETTER_AUTH_SECRET=dev-secret-change-in-production-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:8080

# Optional: OAuth Providers
# Configure only if you want to enable social authentication
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# See packages/backend-common/src/env.ts and apps/server/env.ts for validation schema
