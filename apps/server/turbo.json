{
  "extends": ["//"],
  "tasks": {
    "build:vercel": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/packages/*/src/**",
        "$TURBO_ROOT$/packages/*/package.json"
      ],
      "outputs": ["dist/**"]
    },
    "build": {
      "inputs": [
        "$TURBO_EXTENDS$",
        "$TURBO_ROOT$/packages/*/src/**",
        "$TURBO_ROOT$/packages/*/package.json"
      ],
      "outputs": ["dist/**"]
    }
  }
}
