{
  "extends": "@template/typescript-config/backend.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@template/store/*": ["../../packages/store/src/*"],
      "@template/auth/*": ["../../packages/auth/src/*"],
      "@template/trpc/*": ["../../packages/trpc/src/*"],
      "@template/backend-common/*": ["../../packages/backend-common/src/*"],
      "@template/common/*": ["../../packages/common/src/*"]
