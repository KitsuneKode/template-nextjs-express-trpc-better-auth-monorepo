{
  "name": "@template/worker",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "check-types": "tsc -noEmit",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify --sourcemap",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/server.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@template/auth": "workspace:*",
    "@template/backend-common": "workspace:*",
    "@template/common": "workspace:*",
    "@template/store": "workspace:*",
    "bullmq": "^5.48.1"
  },
  "devDependencies": {
    "@template/typescript-config": "workspace:*",
    "@types/bun": "1.3.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
