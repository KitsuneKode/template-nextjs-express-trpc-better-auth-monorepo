{
  "name": "@arche-template/worker",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify --sourcemap",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/server.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@arche-template/auth": "workspace:*",
    "@arche-template/backend-common": "workspace:*",
    "@arche-template/common": "workspace:*",
    "@arche-template/store": "workspace:*",
    "bullmq": "^5.76.10"
  },
  "devDependencies": {
    "@arche-template/typescript-config": "workspace:*",
    "@types/bun": "1.3.14"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
