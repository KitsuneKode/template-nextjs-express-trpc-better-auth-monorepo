{
  "name": "@kitsu/create",
  "version": "0.2.0",
  "description": "Bootstrap production-ready full-stack TypeScript monorepos with Next.js, Express, tRPC, and Better Auth",
  "keywords": [
    "better-auth",
    "boilerplate",
    "cli",
    "express",
    "fullstack",
    "monorepo",
    "nextjs",
    "prisma",
    "scaffold",
    "starter",
    "template",
    "trpc",
    "turborepo",
    "typescript"
  ],
  "homepage": "https://github.com/kitsunekode/template-nextjs-express-trpc-bettera-auth-monorepo#readme",
  "bugs": {
    "url": "https://github.com/kitsunekode/template-nextjs-express-trpc-bettera-auth-monorepo/issues"
  },
  "license": "MIT",
  "author": "kitsunekode <bhuyanmanash2002@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitsunekode/template-nextjs-express-trpc-bettera-auth-monorepo.git",
    "directory": "apps/cli"
  },
  "bin": {
    "@kitsu/create": "dist/index.js",
    "create-kitsu-stack": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target node --minify",
    "build:dev": "bun build ./src/index.ts --outfile ./dist/index.js --target node",
    "dev": "bun run ./src/index.ts",
    "link": "bun run build && bun link",
    "unlink": "bun unlink",
    "test": "bun test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@template/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
