{
  "name": "create-kitsu-stack",
  "version": "0.1.0",
  "description": "Bootstrap a Kitsu Stack project from the monorepo template",
  "type": "module",
  "bin": {
    "create-kitsu-stack": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target bun",
    "dev": "bun run ./src/index.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@template/eslint-config": "workspace:*",
    "@template/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "eslint": "^9.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
