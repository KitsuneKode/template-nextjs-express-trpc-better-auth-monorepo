{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/refs/heads/main/crates/oxc_linter/src/snapshots/oxlintrc.schema.json",
  "plugins": ["typescript", "import", "react", "react-hooks"],
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "rules": {
    "no-console": "off",
    "typescript/no-unused-vars": ["error", { "args": "none", "varsIgnorePattern": "^_" }],
    "import/default": "error",
    "react/jsx-no-target-blank": "error",
    "react-in-jsx-scope": "off",
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "warn"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  }
}
